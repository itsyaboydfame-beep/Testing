RegisterConnection(s_RunService.Heartbeat:Connect(function(dt)
    if Destructing then return end
    local char = l_LocalPlayer.Character
    if char then
        local hum = char:FindFirstChild("Humanoid")
        if HubState.HitboxActive and hum then hum.WalkSpeed = SaveData.Settings.Speed end
    end
    
    HandleAutoGK()
    
    local target = GetAimTarget()
    if target and r_PrepareShot then
        local payload = r_PrepareShot.GetPayload()
        local requiredCharge = SaveData.Settings.RequiredShotPower / 100
        
        if payload and payload.Active and payload.Shot ~= "Kick" and payload.Charge and payload.Charge >= requiredCharge then
            if r_States.Actions.PrepareShot.PreviousReleaseEndPoint then
                r_States.Actions.PrepareShot.PreviousReleaseEndPoint:set(target)
            end
        end
    end
    
    for _, data in pairs(HubState.ActiveMarkers) do
        if data.MarkerPart and data.TargetPart then data.MarkerPart.Position = data.TargetPart.CFrame:PointToWorldSpace(data.Offset) end
    end

    -- Update Trajectory Visualizer Loop
    goalUpdateAccum += dt
    if goalUpdateAccum >= GOAL_UPDATE_INTERVAL then
        goalUpdateAccum = 0
        updateGoalHighlight()
    end

    local balls = s_CollectionService:GetTagged("Football")
    if #balls > 0 then
        local ball = balls[1]
        local pos = ball.Position
        local velocity = ball.AssemblyLinearVelocity
        local speed = velocity.Magnitude
        
        local velChange = lastVel and (velocity - lastVel).Magnitude or 0
        if wasHighSpeed and velChange > 12 then predictionLockedForThisShot = false end

        if speed > MIN_SHOT_SPEED and not predictionLockedForThisShot then
            wasHighSpeed = true predictionLockedForThisShot = true
            local isPass = (ball:GetAttribute("Action") == "Pass") or (ball:GetAttribute("KickType") == "Pass") or (math.abs(velocity.Y) <= PASS_Y_THRESHOLD)
            calculateAndDrawTrajectoryWrapper(pos, velocity, isPass)
        elseif speed < 5 and wasHighSpeed then
            wasHighSpeed = false predictionLockedForThisShot = false
        end
        
        if wasHighSpeed then
            trailAccum += dt
            if lastTrailPos and trailAccum >= ACTUAL_TRAIL_STEP then
                drawActualPathSegment(lastTrailPos, pos) lastTrailPos = pos trailAccum = 0
            elseif not lastTrailPos then lastTrailPos = pos end
        else lastTrailPos = nil trailAccum = 0 end

        if lastVel and wasHighSpeed and math.abs(velocity.Y) > PASS_Y_THRESHOLD then
            if lastVel.Y < -1 and velocity.Y > 0.5 then drawActualLandingMarker(pos, Vector3.new(0, 1, 0)) end
        end
        lastVel = velocity
    end
end))

r_PrepareShot.GetCameraDirection = function()
    if Destructing then return oldDir() end
    local target = GetAimTarget()
    if target then
        local payload = r_PrepareShot.GetPayload()
        local requiredCharge = SaveData.Settings.RequiredShotPower / 100
        
        if payload and payload.Active and payload.Shot ~= "Kick" and payload.Charge and payload.Charge >= requiredCharge then
            local hrp = l_LocalPlayer.Character and l_LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            if hrp then
                local dir = (target - hrp.Position).Unit
                return Vector3.new(dir.X, 0, dir.Z).Unit
            end
        end
    end
    return oldDir()
end

