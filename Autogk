local function findCorrectPart(partName, worldPos)
    local bestPart, shortestDist = nil, math.huge
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("BasePart") and obj.Name == partName then
            local dist = (obj.Position - worldPos).Magnitude
            if dist < shortestDist then shortestDist = dist; bestPart = obj end
        end
    end
    return (shortestDist < 100) and bestPart or nil
end

