-- // INPUT HANDLING //
RegisterConnection(s_UserInputService.InputBegan:Connect(function(input, processed)
    if Destructing then return end
    if not processed then
        if input.KeyCode == Enum.KeyCode.K then 
            MainFrame.Visible = not MainFrame.Visible 
        end
        if input.KeyCode == Enum.KeyCode.Comma then 
            UI.Enabled = false
        elseif input.KeyCode == Enum.KeyCode.Period then 
            UI.Enabled = true
        end
    end
    
    if HubState.SettingTarget and (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) then
        HubState.SettingTarget = false
        MainFrame.Visible = true
        
        local unitRay = l_Camera:ViewportPointToRay(input.Position.X, input.Position.Y)
        local res = workspace:Raycast(unitRay.Origin, unitRay.Direction * 1000)
        if res and res.Instance then
            RecordState()
            local team = getMySide()
            if not team then return end
            if not SaveData.Targets[team] then SaveData.Targets[team] = {} end
            table.insert(SaveData.Targets[team], {
                PartName = res.Instance.Name,
                Off = {res.Instance.CFrame:PointToObjectSpace(res.Position).X, res.Instance.CFrame:PointToObjectSpace(res.Position).Y, res.Instance.CFrame:PointToObjectSpace(res.Position).Z},
                WorldPos = {res.Position.X, res.Position.Y, res.Position.Z}
            })
            SaveAllData(); RefreshMarkers()
            Notify("Target Added", "Placed target on " .. res.Instance.Name)
        else
            Notify("Target Cancelled", "No valid part was clicked.")
        end
    end
end))

RefreshMarkers()
