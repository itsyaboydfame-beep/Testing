local function isInFOV(targetPos, maxFOV)
    local unitToTarget = (targetPos - l_Camera.CFrame.Position).Unit
    local lookVec = l_Camera.CFrame.LookVector
    local dotProduct = math.clamp(lookVec:Dot(unitToTarget), -1, 1)
    local angle = math.deg(math.acos(dotProduct))
    return angle <= (maxFOV / 2)
end

-- // AIM LOGIC // --
local function getBestTargetPos()
    local char = l_LocalPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp or #HubState.ActiveMarkers == 0 then return nil end

    local bars = getOpponentGoalBars()
    if not bars then return nil end
    
    local goalCF, goalSize = bars:GetBoundingBox()
    local relPos = goalCF:PointToObjectSpace(hrp.Position)
    local halfWidth = (goalSize.X / 2) + SaveData.Settings.SafeZonePadding
    if math.abs(relPos.X) > halfWidth then return nil end

    local anyInRange = false
    local minPlayerDist = math.huge
    local allPotentialTargets = {}

    for _, data in pairs(HubState.ActiveMarkers) do
        if data.TargetPart then
            local worldPos = data.TargetPart.CFrame:PointToWorldSpace(data.Offset)
            local distToMe = (worldPos - hrp.Position).Magnitude
            if distToMe <= SaveData.Settings.MaxRange and isInFOV(worldPos, SaveData.Settings.MaxFOV) then 
                anyInRange = true 
                if distToMe < minPlayerDist then minPlayerDist = distToMe end
                table.insert(allPotentialTargets, {pos = worldPos, distMe = distToMe})
            end
        end
    end

    if not anyInRange then return nil end
    
    local gkPos = getGKPosition()
    if minPlayerDist <= SaveData.Settings.FarModeThreshold then
        local bestPos, closestDist = nil, math.huge
        for _, t in pairs(allPotentialTargets) do if t.distMe < closestDist then closestDist = t.distMe bestPos = t.pos end end
        return bestPos
    else
        if gkPos then
            local bestPos, maxGkDist = nil, -1
            for _, t in pairs(allPotentialTargets) do
                local distToGk = (t.pos - gkPos).Magnitude
                if distToGk > maxGkDist then maxGkDist = distToGk bestPos = t.pos end
            end
            return bestPos
        else
            local bestPos, closestDist = nil, math.huge
            for _, t in pairs(allPotentialTargets) do if t.distMe < closestDist then closestDist = t.distMe bestPos = t.pos end end
            return bestPos
        end
    end
end

local function getBestTeammatePos()
    local hrp = l_LocalPlayer.Character and l_LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return nil end

    local myTeam = getMySide()
    local potentialTargets = {}
    local center = Vector2.new(l_Camera.ViewportSize.X / 2, l_Camera.ViewportSize.Y / 2)

    for _, plr in pairs(s_Players:GetPlayers()) do
        if plr ~= l_LocalPlayer then
            local char = plr.Character
            local targetHrp = char and char:FindFirstChild("HumanoidRootPart")
            local theirTeam = plr:GetAttribute("IsHomeOrAway") or (char and char:GetAttribute("IsHomeOrAway"))
            
            if targetHrp and theirTeam == myTeam then
                local dist = (targetHrp.Position - hrp.Position).Magnitude
                if dist <= SaveData.Settings.TeammateMaxRange and isInFOV(targetHrp.Position, SaveData.Settings.TeammateMaxFOV) then
                    local screenPos, onScreen = l_Camera:WorldToViewportPoint(targetHrp.Position)
                    local distCenter = onScreen and (Vector2.new(screenPos.X, screenPos.Y) - center).Magnitude or math.huge
                    table.insert(potentialTargets, {pos = targetHrp.Position, distMe = dist, distCenter = distCenter})
                end
            end
        end
    end
    
    if #potentialTargets == 0 then return nil end
    local bestPos, bestVal = nil, math.huge
    local mode = SaveData.Settings.TeammateAimMode
    
    for _, t in pairs(potentialTargets) do
        local val = (mode == "Nearest") and t.distMe or t.distCenter
        if val < bestVal then bestVal = val; bestPos = t.pos end
    end
    return bestPos
end

local function GetAimTarget()
    local hrp = l_LocalPlayer.Character and l_LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return nil end
    
    local minMarkerDist = math.huge
    for _, data in pairs(HubState.ActiveMarkers) do
        if data.TargetPart then
            local worldPos = data.TargetPart.CFrame:PointToWorldSpace(data.Offset)
            local dist = (worldPos - hrp.Position).Magnitude
            if dist < minMarkerDist then minMarkerDist = dist end
        end
    end

    if minMarkerDist <= SaveData.Settings.MaxRange then
        if SaveData.Settings.GoalAimbotMaster then return getBestTargetPos() end
    else
        if SaveData.Settings.TeammateAimAssist then return getBestTeammatePos() end
    end
    return nil
end

