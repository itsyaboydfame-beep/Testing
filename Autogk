local function getPlayerRole()
    local attrs = {"TeamPosition", "Position", "Role"}
    for _, attr in ipairs(attrs) do
        local val = l_LocalPlayer:GetAttribute(attr)
        if val then return tostring(val) end
    end
    for _, attr in ipairs(attrs) do
        local val = l_LocalPlayer:FindFirstChild(attr)
        if val and val:IsA("StringValue") then return val.Value end
    end
    return "Unknown"
end

local function autoGkDive(targetPos, rootPart)
    local controller = getActionController()
    if not controller then return end

    if controller.IsOnCooldown and controller:IsOnCooldown("Leap") then return end
    if tick() - lastDiveTime < GK_COOLDOWN_TIME then return end

    local toball   = targetPos - rootPart.Position
    local forward  = rootPart.CFrame.LookVector
    local rightVec = rootPart.CFrame.RightVector

    local forwardDot = toball:Dot(forward)
    local rightDot   = toball:Dot(rightVec)

    local diveDirection
    if math.abs(rightDot) > math.abs(forwardDot) * 0.5 then
        if rightDot > 0 then diveDirection = "Right" else diveDirection = "Left" end
    else diveDirection = "Forward" end

    local lookCF = CFrame.lookAt(rootPart.Position, Vector3.new(targetPos.X, rootPart.Position.Y, targetPos.Z))
    rootPart.CFrame = lookCF

    pcall(function() controller:PerformAction("Leap", diveDirection) end)
    lastDiveTime = tick()
end

local function HandleAutoGK()
    if SaveData.Settings.AutoGK ~= true then return end -- Strict boolean check
    local role = getPlayerRole()
    if role ~= "GK" and role ~= "Goalkeeper" then return end

    local ball = getBall()
    local char = l_LocalPlayer.Character
    local rootPart = char and char:FindFirstChild("HumanoidRootPart")
    if not ball or not rootPart then return end

    local distance = (ball.Position - rootPart.Position).Magnitude
    local ownerName = ball:GetAttribute("NetworkOwner")
    local isMe = (ownerName == l_LocalPlayer.Name)
    local isLoose = (not ownerName or ownerName == "")
    local isOpponent = false

    if ownerName and not isMe and not isLoose then
        local p = s_Players:FindFirstChild(ownerName)
        if p and (not p.Team or (l_LocalPlayer.Team and p.Team ~= l_LocalPlayer.Team)) then isOpponent = true end
    end

    if (isOpponent and distance <= 15) or (isLoose and distance <= 14) then
        autoGkDive(ball.Position, rootPart)
    end
end

