local function isEnemyGK(entity, opponentSide)
    if not entity then return false end
    local side = entity:GetAttribute("IsHomeOrAway")
    local role = entity:GetAttribute("TeamRole") or entity:GetAttribute("TeamPosition")
    return (side == opponentSide) and (role == "Goalkeeper" or role == "GK")
end

local function getGKPosition()
    local mySide = getMySide()
    if not mySide then return nil end
    local opponentSide = (mySide == "Home") and "Away" or "Home"

    for _, plr in pairs(s_Players:GetPlayers()) do
        local char = plr.Character
        if char and (isEnemyGK(char, opponentSide) or isEnemyGK(plr, opponentSide)) then
            local hrp = char:FindFirstChild("HumanoidRootPart")
            if hrp then return hrp.Position end
        end
    end
    local agentFolder = workspace:FindFirstChild("Systems") and workspace.Systems:FindFirstChild("Agents")
    if agentFolder then
        for _, npc in pairs(agentFolder:GetChildren()) do
            if isEnemyGK(npc, opponentSide) then
                local hrp = npc:FindFirstChild("HumanoidRootPart") or npc:FindFirstChild("Hitbox")
                if hrp then return hrp.Position end
            end
        end
    end
    return nil
end

