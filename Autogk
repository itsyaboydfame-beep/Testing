local cmds = { {"Up", UDim2.new(0.5, -25, 0, 25), 2, 1}, {"Dn", UDim2.new(0.5, -25, 0, 55), 2, -1}, {"L", UDim2.new(0.5, -55, 0, 40), 3, 1}, {"R", UDim2.new(0.5, 5, 0, 40), 3, -1}, {"Fwd", UDim2.new(0.5, -95, 0, 25), 1, 1}, {"Bck", UDim2.new(0.5, -95, 0, 55), 1, -1} }
for _, d in pairs(cmds) do
    local b = Instance.new("TextButton", adjustFrame) b.Size = UDim2.new(0, 25, 0, 20) b.Position = d[2] b.BackgroundColor3 = Color3.fromRGB(45, 45, 55) b.Text, b.TextColor3, b.Font, b.TextSize = d[1], Color3.new(1,1,1), Enum.Font.GothamBold, 10 Instance.new("UICorner", b).CornerRadius = UDim.new(0, 4)
    b.MouseButton1Click:Connect(function()
        local bestM, bestS = nil, math.huge
        local center = Vector2.new(l_Camera.ViewportSize.X / 2, l_Camera.ViewportSize.Y / 2)
        for _, m in pairs(HubState.ActiveMarkers) do
            local sp = l_Camera:WorldToViewportPoint(m.TargetPart.CFrame:PointToWorldSpace(m.Offset))
            local dist = (Vector2.new(sp.X, sp.Y) - center).Magnitude
            if dist < bestS then bestS = dist; bestM = m end
        end
        if bestM then RecordState(); local entry = SaveData.Targets[getMySide()][bestM.DataIndex]; entry.Off[d[3]] = entry.Off[d[3]] + (0.5 * d[4]); SaveAllData(); RefreshMarkers() end
    end)
end
