local function createAndStabilizePart(part, name)
    local existingClone = part.Parent:FindFirstChild(name)
    if existingClone then existingClone:Destroy() end
    local clone = Instance.new("Part")
    clone.Size = Vector3.new(SaveData.Settings.HitboxSizeX, SaveData.Settings.HitboxSizeY, SaveData.Settings.HitboxSizeZ)
    clone.CanCollide, clone.Transparency, clone.BrickColor, clone.Name, clone.Position, clone.Anchored, clone.Parent = false, SaveData.Settings.HitboxTransparency, BrickColor.new("Bright red"), name, part.Position, false, part.Parent

    local attach0 = Instance.new("Attachment", part)
    local attach1 = Instance.new("Attachment", clone)

    local alignPos = Instance.new("AlignPosition", clone)
    alignPos.Attachment0, alignPos.Attachment1, alignPos.RigidityEnabled = attach1, attach0, true

    local alignOri = Instance.new("AlignOrientation", clone)
    alignOri.Attachment0, alignOri.Attachment1, alignOri.RigidityEnabled = attach1, attach0, true
end

local function expandParts()
    local character = l_LocalPlayer.Character
    if character then
        local parts = {"LowerTorso", "UpperTorso", "HumanoidRootPart", "Left Arm", "Right Arm", "Left Leg", "Right Leg", "LeftHand", "RightHand", "LeftFoot", "RightFoot"}
        for _, partName in pairs(parts) do
            local part = character:FindFirstChild(partName)
            if part then createAndStabilizePart(part, partName .. "_Expanded") end
        end
    end
end

local function removeExpandedParts()
    local character = l_LocalPlayer.Character
    if character then
        for _, part in pairs(character:GetChildren()) do
            if part:IsA("Part") and part.Name:match("_Expanded") then part:Destroy() end
        end
    end
end

