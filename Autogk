local function buildRayParams()
    local rayParams = RaycastParams.new() rayParams.FilterType = Enum.RaycastFilterType.Exclude
    local ignoreList = s_CollectionService:GetTagged("Football")
    for _, player in ipairs(s_Players:GetPlayers()) do if player.Character then table.insert(ignoreList, player.Character) end end
    rayParams.FilterDescendantsInstances = ignoreList rayParams.IgnoreWater = false return rayParams
end

local function raycastWithFallback(origin, direction, rayParams)
    local result = workspace:Raycast(origin, direction, rayParams)
    if result then return result end
    local segmentLength = direction.Magnitude if segmentLength < 0.001 then return nil end
    local steps = math.clamp(math.ceil(segmentLength / 0.5), 6, 40)
    local sampleRadius = 1.5 
    for i = 1, steps do
        local alpha = i / steps local point = origin + direction * alpha
        local overlapParams = OverlapParams.new() overlapParams.FilterType = rayParams.FilterType overlapParams.FilterDescendantsInstances = rayParams.FilterDescendantsInstances
        local parts = workspace:GetPartBoundsInRadius(point, sampleRadius, overlapParams)
        for _, part in ipairs(parts) do
            if part.Name ~= "HumanoidRootPart" then return { Position = point, Normal = (origin - point).Unit, Instance = part } end
        end
    end
    return nil
end

local function calculateAndDrawTrajectory(startPos, initialVelocity, isPass, onBounce)
    if SaveData.Settings.PredictionDisappearMode == "Next Kick" then
        clearPredictionLines()
    end
    
    local rayParams = buildRayParams()
    local GRAVITY = isPass and Vector3.zero or Vector3.new(0, -workspace.Gravity, 0)
    local currentPos, currentVel, stopped = startPos, initialVelocity, false

    for t = 0, PREDICTION_TIME, TIME_STEP do
        if stopped then break end
        local nextPos = currentPos + (currentVel * TIME_STEP)
        local nextVel
        
        -- STRICT Y-LEVEL HARDCAP:
        if nextPos.Y <= -7.0 then
            local ySpeed = -currentVel.Y
            if ySpeed == 0 then ySpeed = 0.001 end
            local timeToHit = (currentPos.Y - (-7.0)) / ySpeed
            timeToHit = math.clamp(timeToHit, 0, TIME_STEP)
            nextPos = currentPos + currentVel * timeToHit
            nextPos = Vector3.new(nextPos.X, -7.0, nextPos.Z)
            
            drawLineSegment(currentPos, nextPos, isPass)
            drawBouncePredictionCircle(nextPos, Vector3.new(0, 1, 0))
            stopped = true
            break
        end
        
        if isPass then
            local currentSpeed = currentVel.Magnitude
            if currentSpeed > MIN_PASS_SPEED then
                local newSpeed = currentSpeed - (PASS_FRICTION * TIME_STEP)
                if newSpeed <= MIN_PASS_SPEED then nextVel = Vector3.zero stopped = true
                else nextVel = currentVel.Unit * newSpeed end
            else nextVel = Vector3.zero stopped = true end
        else nextVel = currentVel + (GRAVITY * TIME_STEP) end

        local delta = nextPos - currentPos
        local raycastResult = nil
        if delta.Magnitude > 0.001 then raycastResult = raycastWithFallback(currentPos, delta, rayParams) end

        if raycastResult then
            drawLineSegment(currentPos, raycastResult.Position, isPass)
            drawBouncePredictionCircle(raycastResult.Position, raycastResult.Normal)
            if onBounce then onBounce(raycastResult.Position) end
            stopped = true
        else
            drawLineSegment(currentPos, nextPos, isPass)
            currentPos, currentVel = nextPos, nextVel
        end
    end
end

local function getClosestGoal()
    local character = l_LocalPlayer.Character
    if not character or not character:FindFirstChild("HumanoidRootPart") then return nil end
    local myPos = character.HumanoidRootPart.Position
    local goals = s_CollectionService:GetTagged(GOAL_TAG)
    local closestGoal, closestDist = nil, math.huge

    for _, goal in ipairs(goals) do
        local goalPos
        if goal:IsA("BasePart") then goalPos = goal.Position elseif goal:IsA("Model") then goalPos = goal:GetPivot().Position end
        if goalPos then
            local dist = (goalPos - myPos).Magnitude
            if dist < closestDist then closestDist = dist closestGoal = goal end
        end
    end
    return closestGoal
end

local function highlightGoal(goal)
    if currentHighlight then currentHighlight:Destroy() currentHighlight = nil end
    if not goal then return end
    local highlight = Instance.new("Highlight")
    highlight.Name = "ClosestGoalHighlight" highlight.FillColor = Color3.fromRGB(0, 170, 255) highlight.FillTransparency = 0.6 highlight.OutlineColor = Color3.fromRGB(0, 220, 255) highlight.OutlineTransparency = 0 highlight.Adornee = goal highlight.Parent = goal
    currentHighlight = highlight
end

local function updateGoalHighlight()
    if not SaveData.Settings.HighlightClosestGoal then
        if currentHighlight then currentHighlight:Destroy() currentHighlight = nil end return
    end
    local closest = getClosestGoal()
    if closest ~= (currentHighlight and currentHighlight.Adornee) then highlightGoal(closest) end
end

local function calculateAndDrawTrajectoryWrapper(startPos, initialVelocity, isPass)
    local scale = isPass and PASS_PREDICTION_SCALE or PREDICTION_SCALE
    local scaledVelocity = initialVelocity * scale
    calculateAndDrawTrajectory(startPos, scaledVelocity, isPass)
end


